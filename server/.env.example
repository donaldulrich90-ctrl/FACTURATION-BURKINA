# Base SQLite (par défaut - aucune installation)
DATABASE_URL="file:./dev.db"

# Pour PostgreSQL en production :
# DATABASE_URL="postgresql://user:password@localhost:5432/fasomarches?schema=public"

# JWT — OBLIGATOIRE en production : générez une clé forte (openssl rand -base64 32)
JWT_SECRET="changez-moi-en-production-avec-une-cle-longue-et-aleatoire"
JWT_EXPIRES_IN="7d"

# Production : définir pour activer les contrôles de sécurité
# NODE_ENV=production

# CORS : en production, liste des origines autorisées séparées par des virgules
# CORS_ORIGINS=https://votre-domaine.com,https://app.votre-domaine.com

# Assistant IA — une des deux options suffit
# Option 1 : Groq (GRATUIT) — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# Option 2 : OpenAI (payant) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Port du serveur
PORT=3001

# Expiration automatique des abonnements (intervalle en millisecondes)
# 3600000 = 1 heure | 86400000 = 24 heures (1 jour)
# 0 ou vide = désactivé
SUBSCRIPTION_EXPIRE_INTERVAL_MS=3600000
