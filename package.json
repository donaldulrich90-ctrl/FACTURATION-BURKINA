{
  "name": "facturation-fasomarches",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"npm run dev:server\" \"vite\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "vite",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:render": "npm install && npm run build && cd server && npm install && node ./node_modules/prisma/build/index.js generate && node ./node_modules/prisma/build/index.js db push",
    "start": "npm run build && cd server && node src/index.js",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-pdf-worker.cjs",
    "guide:pdf": "npx --yes md-to-pdf GUIDE_ENTREPRISES.md -o GUIDE_ENTREPRISES.pdf",
    "guide:ouvrir": "start GUIDE_ENTREPRISES.html"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.1"
  }
}
