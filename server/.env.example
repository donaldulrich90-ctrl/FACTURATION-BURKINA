# Base SQLite (par défaut - aucune installation)
DATABASE_URL="file:./dev.db"

# Pour PostgreSQL en production :
# DATABASE_URL="postgresql://user:password@localhost:5432/fasomarches?schema=public"

# JWT
JWT_SECRET="changez-moi-en-production-avec-une-cle-longue-et-aleatoire"
JWT_EXPIRES_IN="7d"

# Port du serveur
PORT=3001

# Expiration automatique des abonnements (intervalle en millisecondes)
# 3600000 = 1 heure | 86400000 = 24 heures (1 jour)
# 0 ou vide = désactivé
SUBSCRIPTION_EXPIRE_INTERVAL_MS=3600000
