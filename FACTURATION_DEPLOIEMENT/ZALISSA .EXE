import React, { useState } from 'react';
import { 
  Snowflake, Truck, CreditCard, CheckCircle, Zap, 
  MessageCircle, Wrench, Package, User, Download, 
  ImageIcon, Loader2, Sparkles 
} from 'lucide-react';

const App = () => {
  const [generating, setGenerating] = useState(false);
  const [photoUrl, setPhotoUrl] = useState(null);
  const [error, setError] = useState(null);

  const contactNumbers = ["76 83 40 51", "70 76 81 28"];
  const promoterName = "MAMAN ZALIA";
  const apiKey = ""; // La clé est injectée automatiquement par l'environnement

  const products = [
    {
      power: "1 CV",
      model: "JACK STARS",
      tech: "Inverter Technology",
      price: "195.000 FCFA",
      advance: "130.000 FCFA",
      balance: "65.000 FCFA",
      color: "from-blue-600 to-indigo-900"
    },
    {
      power: "1.5 CV",
      model: "JACK STARS",
      tech: "Inverter Technology",
      price: "221.000 FCFA",
      advance: "140.000 FCFA",
      balance: "81.000 FCFA",
      color: "from-blue-500 via-blue-700 to-indigo-900"
    }
  ];

  // Fonction pour transformer l'affiche en photo via l'IA Gemini
  const generatePhoto = async () => {
    setGenerating(true);
    setError(null);
    
    // Prompt optimisé pour être fidèle à la mise en page actuelle
    const prompt = `Crée une affiche publicitaire haute résolution (8k) pour climatiseurs JACK STARS INVERTER, fidèle à cette structure précise :
    1. HAUT : Dégradé bleu vif avec texte "JACK STARS INVERTER" en blanc gras et nom de promotrice "MAMAN ZALIA".
    2. BANDEAU JAUNE : Une ligne horizontale jaune avec les mentions "Transport Inclus" et "Technologie Inverter".
    3. CORPS : Deux cartes de produits élégantes montrant "1 CV : 195.000 FCFA" et "1.5 CV : 221.000 FCFA" avec les détails de l'avance et du solde.
    4. SERVICES : Trois icônes (camion, colis, clé à molette) avec le texte "À VOS FRAIS" écrit en rouge pour la livraison et la pose.
    5. BAS : Un pied de page bleu nuit très sombre contenant un encadré avec les numéros WhatsApp 76 83 40 51 et 70 76 81 28.
    Style : Graphisme moderne, professionnel, couleurs saturées bleu électrique et jaune éclatant, netteté maximale.`;

    const payload = {
      contents: [{
        parts: [{ text: prompt }]
      }],
      generationConfig: {
        responseModalities: ['IMAGE']
      }
    };

    let delay = 1000;
    for (let i = 0; i < 5; i++) {
      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${apiKey}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) throw new Error();

        const result = await response.json();
        const base64Data = result.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
        
        if (base64Data) {
          setPhotoUrl(`data:image/png;base64,${base64Data}`);
          setGenerating(false);
          return;
        }
      } catch (err) {
        if (i === 4) {
          setError("Erreur de génération. Veuillez prendre une capture d'écran de l'affiche ci-dessous pour une fidélité à 100%.");
          setGenerating(false);
        } else {
          await new Promise(r => setTimeout(r, delay));
          delay *= 2;
        }
      }
    }
  };

  return (
    <div className="min-h-screen bg-slate-300 flex flex-col items-center py-10 px-4 font-sans selection:bg-blue-200">
      
      {/* Barre d'outils de sauvegarde */}
      <div className="max-w-4xl w-full mb-8 flex flex-col md:flex-row items-center justify-between bg-blue-900 p-6 rounded-[2rem] shadow-2xl gap-4">
        <div className="text-white">
          <h3 className="font-black flex items-center gap-2 text-lg uppercase tracking-tight">
            <Sparkles className="text-yellow-400" size={24} /> 
            Capture Haute Fidélité
          </h3>
          <p className="text-blue-200 text-xs italic">L'IA va maintenant recréer l'affiche avec tous ses détails.</p>
        </div>
        <button 
          onClick={generatePhoto}
          disabled={generating}
          className="bg-yellow-400 text-blue-900 hover:bg-white px-8 py-3 rounded-2xl font-black transition-all flex items-center gap-3 shadow-xl active:scale-95 disabled:opacity-50"
        >
          {generating ? <Loader2 className="animate-spin" /> : <ImageIcon size={20} />}
          {generating ? "CONSTRUCTION DE L'IMAGE..." : "GÉNÉRER LA PHOTO FIDÈLE"}
        </button>
      </div>

      {error && (
        <div className="max-w-4xl w-full mb-6 p-4 bg-red-100 border border-red-200 text-red-700 rounded-2xl font-bold text-center">
          {error}
        </div>
      )}

      {/* Rendu de la Photo IA */}
      {photoUrl && (
        <div className="max-w-4xl w-full mb-12 animate-in fade-in slide-in-from-bottom-8 duration-700">
          <div className="bg-white p-3 rounded-[2.5rem] shadow-[0_40px_80px_-15px_rgba(0,0,0,0.5)] border-4 border-blue-500 relative">
            <div className="absolute top-6 left-6 bg-blue-600 text-white px-4 py-1 rounded-full text-[10px] font-black z-10 shadow-lg uppercase">Version Image HD</div>
            <img src={photoUrl} alt="Affiche Jack Stars Finale" className="w-full rounded-[2rem] shadow-inner" />
          </div>
          <div className="mt-6 flex flex-col items-center gap-2">
            <p className="text-blue-900 font-black flex items-center gap-2 uppercase tracking-widest text-sm text-center">
               <Download size={20} /> Appuyez longuement sur l'image pour l'enregistrer
            </p>
            <button 
              onClick={() => setPhotoUrl(null)}
              className="text-slate-500 text-xs underline font-medium"
            >
              Fermer et revenir au design
            </button>
          </div>
          <div className="h-px bg-slate-400 w-full my-12 opacity-30"></div>
        </div>
      )}

      {/* Affiche Graphique (Capture Directe) */}
      {!photoUrl && (
        <div id="poster-capture" className="max-w-4xl w-full bg-white shadow-[0_50px_100px_-20px_rgba(30,64,175,0.3)] rounded-[3rem] overflow-hidden relative border border-white/20">
          
          {/* Header - Bleus Vifs */}
          <div className="bg-gradient-to-br from-blue-600 via-blue-800 to-indigo-950 p-12 text-center text-white relative">
            <div className="absolute top-0 right-0 p-10 opacity-10">
              <Snowflake size={220} />
            </div>
            <div className="relative z-10 space-y-4">
              <div className="flex flex-col items-center gap-3 mb-6">
                <div className="bg-white/20 backdrop-blur-md border border-white/30 text-white text-[10px] font-black px-6 py-2 rounded-full tracking-[0.3em] uppercase shadow-lg">
                  Économie d'énergie • Haute Performance
                </div>
                <div className="flex items-center gap-2 text-cyan-300 font-bold uppercase tracking-[0.2em] text-xs drop-shadow-md">
                  <User size={16} />
                  <span>Promotrice : {promoterName}</span>
                </div>
              </div>
              <h1 className="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-2 drop-shadow-[0_5px_15px_rgba(0,0,0,0.3)] text-white">JACK STARS</h1>
              <h2 className="text-3xl md:text-4xl font-light tracking-[0.6em] text-cyan-400 mb-6 uppercase drop-shadow-md">INVERTER</h2>
              <div className="w-32 h-2 bg-yellow-400 mx-auto rounded-full shadow-[0_0_15px_rgba(250,204,21,0.5)]"></div>
            </div>
          </div>

          {/* Info Banner */}
          <div className="bg-yellow-400 py-5 text-center shadow-xl relative z-20 flex justify-center gap-10 px-8 border-y-2 border-yellow-500">
            <div className="text-blue-900 font-black uppercase tracking-widest text-[11px] flex items-center gap-2">
              <CheckCircle size={20} className="text-blue-800" /> Transport inclus dans le prix
            </div>
            <div className="text-blue-900 font-black uppercase tracking-widest text-[11px] flex items-center gap-2">
              <Zap size={20} className="text-blue-800" /> Inverter • 60% Économie
            </div>
          </div>

          {/* Produits */}
          <div className="p-10 md:p-14 grid md:grid-cols-2 gap-12 bg-slate-50">
            {products.map((item, index) => (
              <div key={index} className="flex flex-col rounded-[2.5rem] overflow-hidden shadow-2xl border border-slate-200 bg-white">
                <div className={`bg-gradient-to-br ${item.color} p-8 text-white text-center relative`}>
                  <h2 className="text-6xl font-black mb-1 drop-shadow-xl">{item.power}</h2>
                  <p className="text-[10px] font-bold text-cyan-300 uppercase tracking-widest italic">{item.tech}</p>
                </div>
                <div className="p-10 space-y-8 flex-grow">
                  <div className="text-center">
                    <span className="text-slate-400 text-[11px] font-black uppercase tracking-[0.4em]">Prix Total</span>
                    <div className="text-5xl font-black text-blue-700 tracking-tighter">{item.price}</div>
                  </div>
                  <div className="space-y-3">
                    <div className="flex justify-between items-center p-4 bg-blue-50/30 rounded-2xl border border-blue-100">
                      <span className="text-blue-500 text-[10px] font-black uppercase tracking-widest">Avance</span>
                      <span className="font-black text-2xl text-slate-900">{item.advance}</span>
                    </div>
                    <div className="flex justify-between items-center p-4 bg-blue-50/30 rounded-2xl border border-blue-100">
                      <span className="text-blue-500 text-[10px] font-black uppercase tracking-widest">Solde réception</span>
                      <span className="font-black text-2xl text-slate-900">{item.balance}</span>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          {/* Services */}
          <div className="bg-white px-12 py-10 border-t border-slate-100">
             <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div className="flex flex-col items-center text-center gap-3 p-6 bg-slate-50 rounded-[2rem] border border-slate-100">
                  <Truck className="text-blue-600" size={24} />
                  <h4 className="font-black text-[10px] uppercase">Livraison Domicile</h4>
                  <p className="text-red-600 text-[10px] font-black uppercase">(À VOS FRAIS)</p>
                </div>
                <div className="flex flex-col items-center text-center gap-3 p-6 bg-slate-50 rounded-[2rem] border border-slate-100 border-l-4 border-l-orange-400">
                  <Package className="text-orange-600" size={24} />
                  <h4 className="font-black text-[10px] uppercase">Envoi Province</h4>
                  <p className="text-red-600 text-[10px] font-black uppercase">(À VOS FRAIS)</p>
                </div>
                <div className="flex flex-col items-center text-center gap-3 p-6 bg-slate-50 rounded-[2rem] border border-slate-100 border-l-4 border-l-green-400">
                  <Wrench className="text-green-600" size={24} />
                  <h4 className="font-black text-[10px] uppercase">Pose & Installation</h4>
                  <p className="text-red-600 text-[10px] font-black uppercase">(À VOS FRAIS)</p>
                </div>
             </div>
          </div>

          {/* Footer Contact */}
          <div className="bg-[#0f172a] p-12 text-white border-t-2 border-blue-500/30">
            <div className="flex flex-col md:flex-row items-center justify-between gap-12">
              <div className="text-center md:text-left space-y-4">
                <p className="text-cyan-400 text-[10px] font-black uppercase tracking-[0.4em]">Service Commercial {promoterName}</p>
                <h3 className="text-4xl font-black uppercase tracking-tighter leading-tight">COMMANDEZ VOTRE UNITÉ</h3>
              </div>
              <div className="bg-white/10 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/20 text-center md:text-right">
                <div className="flex items-center justify-center md:justify-end gap-3 text-green-400 mb-4">
                  <MessageCircle size={32} />
                  <span className="font-black uppercase tracking-[0.2em] text-[10px]">WhatsApp Business</span>
                </div>
                <div className="space-y-2">
                  {contactNumbers.map((num, i) => (
                    <div key={i} className="text-3xl md:text-4xl font-black text-white">{num}</div>
                  ))}
                </div>
              </div>
            </div>
            <div className="mt-12 pt-8 border-t border-white/10 text-center">
              <p className="text-cyan-400 font-black text-2xl uppercase tracking-[0.4em]">JACK STARS : LE CONFORT DURABLE</p>
            </div>
          </div>
        </div>
      )}
      
      <div className="mt-10 opacity-50 flex flex-col items-center gap-1">
        <p className="text-blue-900 text-[10px] font-black uppercase tracking-[0.6em]">Design Officiel Maman Zalia</p>
        <p className="text-blue-900 text-[8px] uppercase tracking-widest">© 2024 JACK STARS INVERTER - OFFRE LIMITÉE</p>
      </div>
    </div>
  );
};

export default App;